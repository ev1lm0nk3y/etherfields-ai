# ==========================================================
#       NanoWakeWord Training Configuration ({{ wake_word }})
# ==========================================================
# This file controls the entire training pipeline for the
# custom wake word "{{ wake_word }}".
# ==========================================================

model_name: "{{ wake_word_slug }}"
output_dir: "{{ models_dir }}"

positive_data_path: "{{ targets_dir }}"
negative_data_path: "{{ negatives_dir }}"

background_paths:
  - "{{ false_positives_dir }}"
  - "{{ negatives_dir }}"

rir_paths: []

# ============================================================
# Model Architecture
# ============================================================
model_type: "transformer"  # SOTA transformer architecture, optimized for Apple Silicon

# ============================================================
# Loss Function
# ============================================================
margin_pos: 2.0       # Positives must score > sigmoid(2.0) ≈ 0.88
margin_neg: -2.0      # Negatives must score < sigmoid(-2.0) ≈ 0.12

LOSS_BIAS: 0.65

# Tighter logit regularization to prevent saturation
logit_reg_weight: 0.0005
logit_reg_margin: 4.0  
logit_min_margin: 1.5  

# ============================================================
# Training Settings
# ============================================================
steps: 50000  # Training steps
stabilization_steps: 20000 # After how many steps will validation be activated?

optimizer_type: "adamw"
learning_rate_max: 0.0008  
lr_scheduler_type: "onecycle"
weight_decay: 0.01
momentum: 0.9
num_workers: 0

# ============================================================
# Distillation (Disabled as requested)
# ============================================================
distillation:
  enabled: false

# ============================================================
# Batch Composition
# ============================================================
batch_composition:
  t: 50
  b: 90
  hn: 20      
  n: 100
  AE28H_float32: 100

# ============================================================
# Feature Manifest
# ============================================================
feature_manifest:
  targets:
    t: "{{ models_dir }}/{{ wake_word_slug }}/features/positive_features.npy"

  negatives:
    AE28H_float32: "{{ train_dir }}/AE29H_float32.npy"
    b: "{{ train_dir }}/RACON_11h_v1.npy"
    n: "{{ models_dir }}/{{ wake_word_slug }}/features/negative_features.npy"
    hn: "{{ models_dir }}/{{ wake_word_slug }}/features/hard_negative_features.npy"

  targets_val:
    t_v: "{{ models_dir }}/{{ wake_word_slug }}/features/positive_features_val.npy"

  negatives_val:
    bv: "{{ train_dir }}/RACON_11h_v1.npy"

# ============================================================
# Synthetic Data Generation (Focus on Negatives & Support)
# ============================================================
target_phrase: "{{ wake_word }}"

data_generation_tasks:
{% if generate_synthetic_positives %}
  # 1. Positive wake word samples (synthetic clones to mix with real recordings)
  - name: "Synthetic Positives"
    enabled: true
    output_dir: "{{ train_dir }}/data/positive"
    num_samples: 2500
    file_prefix: "pos"
    text_source:
      type: "fixed_phrase"
      phrase: "{{ wake_word }}"

  - name: "Synthetic Positives Validation"
    enabled: true
    output_dir: "{{ train_dir }}/data/positive_val"
    num_samples: 2000
    file_prefix: "pos"
    text_source:
      type: "fixed_phrase"
      phrase: "{{ wake_word }}"
{% endif %}

  # 2. Word-based adversarial negatives (auto-synthesized close words)
  - name: "Adversarial Negatives"
    enabled: true
    output_dir: "{{ train_dir }}/data/negative"
    num_samples: 5000
    file_prefix: "neg_auto"
    text_source:
      type: "auto_adversarial"
      base_phrase: "{{ wake_word }}"
      include_input_words: true
      include_partial_phrase: true
      multi_word_prob: 0.5
      max_multi_word_len: 3

  # 3. Phoneme adversarial negatives (phonetically close words)
  - name: "Phoneme Hard Negatives"
    enabled: true
    output_dir: "{{ train_dir }}/data/negative_phoneme"
    num_samples: 3000
    file_prefix: "neg_ph"
    text_source:
      type: "phoneme_adversarial"
      base_phrase: "{{ wake_word }}"
      min_distance: 0.3

  # 4. Custom negative phrases specifically for "{{ wake_word }}"
  - name: "Custom Negatives"
    enabled: true
    output_dir: "{{ train_dir }}/data/negative"
    num_samples: 50
    file_prefix: "neg_custom"
    text_source:
      type: "from_list"
      phrases:
{% for phrase in custom_negatives %}
        - "{{ phrase }}"
{% endfor %}
      repeat_each: 10

# ============================================================
# Augmentation Settings
# ============================================================
augmentation_batch_size: 16
feature_gen_cpu_ratio: 1.0

augmentation_settings:
  max_gain_in_db: 2.0
  min_gain_in_db: -2.0
  max_snr_in_db: 35.0
  min_snr_in_db: 15.0
  max_pitch_semitones: 1.0
  min_pitch_semitones: -1.0
  pitch_prob: 0.3
  gain_prob: 1.0
  rir_prob: 0.0

feature_generation_manifest:
  positives_features_gen:
    input_audio_dirs:
{% if generate_synthetic_positives %}
      - "{{ train_dir }}/data/positive"
{% endif %}
      - "{{ targets_dir }}"
    output_filename: "positive_features.npy"
    use_background_noise: true
    use_rir: false
    augmentation_rounds: 10

  pos_val_features_gen:
    input_audio_dirs:
{% if generate_synthetic_positives %}
      - "{{ train_dir }}/data/positive_val"
{% else %}
      - "{{ targets_dir }}"
{% endif %}
    output_filename: "positive_features_val.npy"
    use_background_noise: true
    use_rir: false
    augmentation_rounds: 10

  negatives_features_gen:
    input_audio_dirs:
      - "{{ train_dir }}/data/negative"
    output_filename: "negative_features.npy"
    use_background_noise: true
    use_rir: false
    augmentation_rounds: 10
  
  hard_negatives_features_gen:
    input_audio_dirs:
      - "{{ train_dir }}/data/negative_phoneme"
    output_filename: "hard_negative_features.npy"
    use_background_noise: true
    use_rir: false
    augmentation_rounds: 1

background_paths_duplication_rate:
  - 1

# ============================================================
# Validation Settings
# ============================================================
val_miss_weight: 4.0
val_fp_weight: 1.0
validation_batch_size: 256
validation_smoothing_window: 3
val_early_stopping_patience: 5000

# ============================================================
# Curriculum Learning
# ============================================================
hardness_ema_alpha: 0.05
hardness_floor: 0.05
hardness_reset_interval: 5000
hardness_reset_decay: 0.5
checkpoint_averaging_top_k: 5

# ============================================================
# Checkpointing & Debug
# ============================================================
checkpointing:
  enabled: true
  interval_steps: 1000
  limit: 2

early_stopping_patience: 0
min_delta: 0.0001
ema_alpha: 0.01

onnx_opset_version: 17
show_training_summary: true
debug_mode: true

# ============================================================
# Pipeline Control
# ============================================================
generate_clips: true
transform_clips: true
train_model: true
overwrite: true
