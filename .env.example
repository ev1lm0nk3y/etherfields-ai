# Etherfields AI Rule Master Configuration Template
# Copy this to '.env' and modify as needed.

# Absolute path to the custom directory where logs, caches, rulebook pages, voice models and audio caches are stored.
# Tilde (~) or environment variables like $HOME can be used; they will be expanded.
ETHERFIELDS_LOCAL_PATH=$HOME/.local/etherfields-ai

# Enable voice assistant and wake-word listener (True/False)
# Use the below section to configure more voice capabilities.
ENABLE_VOICE=False

# ==============================================================================
# Advanced Custom Voice & Generation Configurations
# ==============================================================================

# The active wake-word model name (stored inside ETHERFIELDS_LOCAL_PATH/voice/models/)
# WAKE_WORD_MODEL=jarvis.onnx

# Custom Text-to-Speech WebSocket Server URL
# TTS_WS_URL=ws://127.0.0.1:46290/generate

# Custom directory containing reference voices (.wav) and configuration definitions
# TTS_RESOURCES_DIR=

# Custom audio playback player command (split by space).
# Defaults per OS: 'afplay' (macOS), 'aplay' (Linux), 'start' (Windows).
# Override this to use player commands like mpv, vlc, play, etc.
# AUDIO_PLAYER=afplay

# Custom reference voice overrides for local zero-shot offline voice cloning.
# Specify absolute paths to local .wav sample prompts (at least 5-6 seconds long)
# to clone for the narrative (emotional) and rule instruction (neutral) roles.
# VOICE_REF_NARRATIVE=/path/to/custom_narrator_voice.wav
# VOICE_REF_NARRATIVE_FEARFUL=/path/to/custom_narrator_fearful.wav
# VOICE_REF_NARRATIVE_SAD=/path/to/custom_narrator_sad.wav
# VOICE_REF_NARRATIVE_ANGRY=/path/to/custom_narrator_angry.wav
# VOICE_REF_INSTRUCTION=/path/to/custom_rule_reader_voice.wav
